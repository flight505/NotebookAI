{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NotebookAI",
  "identifier": "com.notebookai.app",
  "version": "0.1.0",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../frontend/out",
    "beforeDevCommand": "cd ../../frontend && pnpm dev",
    "beforeBuildCommand": "cd ../../frontend && pnpm build:tauri"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "NotebookAI",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:8765 ws://localhost:8765 http://127.0.0.1:8765 ws://127.0.0.1:8765"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "appimage", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/notebookai-api"],
    "category": "Productivity",
    "shortDescription": "NotebookAI desktop",
    "longDescription": "NotebookAI: a local-first notebook with retrieval-augmented chat."
  },
  "plugins": {
    "shell": {
      "open": false,
      "scope": [],
      "sidecar": true
    },
    "fs": {
      "scope": ["$APPCONFIG/**", "$APPDATA/**", "$APPLOCALDATA/**", "$DOCUMENT/**"]
    }
  }
}
