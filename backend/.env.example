# NotebookAI backend environment variables.
# Copy to `.env` (or export in your shell) to override defaults.

# Anthropic API key (optional). For personal use, prefer `claude setup-token`
# which writes an OAuth credential file to ~/.claude/.credentials.json.
ANTHROPIC_API_KEY=

# Filesystem root where notebooks live. Default: ~/NotebookAI/notebooks.
NOTEBOOKAI_LIBRARY_ROOT=

# API server bind host. Default: 127.0.0.1 (loopback only).
NOTEBOOKAI_API_HOST=127.0.0.1

# API server port. Default: 8765 (matches frontend NEXT_PUBLIC_API_URL).
NOTEBOOKAI_API_PORT=8765

# Default Claude model used by ingest/query/archive operations.
NOTEBOOKAI_AGENT_MODEL=claude-sonnet-4-6

# Cheaper Claude model used by the scheduled lint pass.
NOTEBOOKAI_LINT_MODEL=claude-haiku-4-5-20251001

# Daily input-token budget for the lint pass (per notebook).
NOTEBOOKAI_LINT_BUDGET_INPUT=50000

# Daily output-token budget for the lint pass (per notebook).
NOTEBOOKAI_LINT_BUDGET_OUTPUT=10000

# SentenceTransformers embedding model for wiki pages.
NOTEBOOKAI_EMB_MODEL=BAAI/bge-small-en-v1.5

# Log level: DEBUG / INFO / WARNING / ERROR.
NOTEBOOKAI_LOG_LEVEL=INFO
